---
import Typography from "./Typography.astro";
import DownloadButton from "./DownloadButton.astro";
---

<header class="header">
    <div class="header-wrapper">
        <Typography
            variant="heading-xs"
            color="primary"
            class="brand"
            as="a"
            href="#top">Yamumi</Typography
        >
        <nav class="nav" aria-label="Основная навигация">
            <Typography
                class="links"
                as="div"
                variant="text-s"
                color="tertiary"
            >
                <a href="#overview">Обзор</a>
                <a href="#minimalism">Изменения</a>
            </Typography>
            <DownloadButton size="s" />
        </nav>
    </div>

    <style>
        .header {
            position: fixed;
            top: 0;
            left: 0;
            background-color: var(--color-background-backdrop);
            border-bottom: 1px solid var(--color-stroke);
            width: 100%;
            backdrop-filter: blur(8px);
            z-index: 9;
        }

        .header-wrapper {
            width: min(
                100% - calc(var(--layout-padding) * 2),
                var(--layout-max)
            );
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 0;
        }

        .brand {
            text-decoration: none;
        }

        .links a {
            text-decoration: none;
            color: inherit;
        }

        .links,
        nav {
            display: flex;
            align-items: center;
            gap: 30px;
        }
    </style>
</header>
