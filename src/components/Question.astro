---
import Typography from "./Typography.astro";

export interface Props {
    title: string;
    children: any;
    class?: string;
}

const { title, class: className, ...rest } = Astro.props;
---

<article class={className} {...rest}>
    <Typography class="question" as="h3" variant="heading-s" color="primary"
        >{title}</Typography
    >
    <Typography as="p" color="quaternary"><slot /></Typography>
</article>

<style>
    .question {
        margin-bottom: 10px;
    }
</style>
