---
import FeatureSection from "../components/FeatureSection.astro";
import FeatureCard from "../components/FeatureGridCard.astro";
---

<FeatureSection wide titleId="mac-title" title="А ещё…">
    <div class="cards">
        <FeatureCard
            iconColor="pink"
            title="Адаптация под контент"
            description="Цвет плеера автоматически подбирается по обложке текущего
        альбома или песни. Интерфейс остаётся лаконичным, но лучше
        сочетается с тем, что играет сейчас."
            wide
        />
        <FeatureCard
            iconColor="pink"
            title="Управление клавиатурой"
            description="Управляйте музыкой прямо с клавиатуры. Даже если не хочется
            отрываться от работы, базовые действия доступны мгновенно."
        />
        <FeatureCard
            iconColor="pink"
            title="Экономия ресурсов"
            description="Yamumi не использует веб-технологии и потребляет в десятки раз
            меньше памяти, чем официальный плеер."
        />
        <FeatureCard
            iconColor="pink"
            title="Тексты песен"
            description="Даже маленький плеер может быть удобным для караоке на рабочем
            месте. Yamumi показывает текст песни, чтобы вы могли подпевать и
            не отвлекаться от дел."
            wide
        />
    </div>
</FeatureSection>

<style>
    .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 36px;
        text-align: left;
    }

    @media (max-width: 760px) {
        .cards {
            grid-template-columns: 1fr;
        }
    }
</style>
