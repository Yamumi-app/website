---
import FeatureSection from "../components/FeatureSection.astro";
import FeatureCard from "../components/FeatureGridCard.astro";
---

<FeatureSection wide titleId="mac-title" title="А ещё…">
    <div class="cards">
        <FeatureCard
            id="adaptation"
            icon="brush"
            title="Адаптация под контент"
            description="Цвет плеера автоматически подбирается по обложке текущего
        альбома или песни. Интерфейс остаётся лаконичным всегда."
            wide
            data-effect="slide"
            data-hold="50"
            data-right="50"
        >
            <img class="colors" src="/colors.png" alt="" />
        </FeatureCard>
        <FeatureCard
            id="keyboard"
            icon="keyboard"
            title="Управление клавиатурой"
            description="Управляйте музыкой прямо с клавиатуры. Базовые действия доступны мгновенно."
        />
        <FeatureCard
            id="resources"
            icon="chip"
            title="Экономия ресурсов"
            description="Yamumi не использует веб-технологии и потребляет в десять раз
            меньше памяти, чем официальный плеер."
        />
        <FeatureCard
            id="lyrics"
            icon="mic"
            title="Тексты песен"
            description="Даже маленький плеер может быть удобным для караоке на рабочем
            месте. Yamumi показывает текст песни, чтобы вы могли подпевать и не отвлекаться от дел."
            wide
        >
            <img class="lyrics" src="/lyrics.png" alt="" />
        </FeatureCard>
    </div>
</FeatureSection>

<style>
    .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 36px;
        text-align: left;
    }

    img {
        width: 289px;
        margin: -37px -24px -37px 0;

        &.lyrics {
            height: 294px;
            aspect-ratio: 289 / 294;
        }

        &.colors {
            height: 230px;
            aspect-ratio: 289 / 230;
        }
    }

    @media (max-width: 760px) {
        .cards {
            grid-template-columns: 1fr;
        }
    }
</style>
