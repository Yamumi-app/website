---
import AppIcon from "../components/AppIcon.astro";
import DownloadButton from "../components/DownloadButton.astro";
import Typography from "../components/Typography.astro";
---

<section class="hero">
    <AppIcon
        id="hero-icon"
        class="honey"
        data-after="hero-title"
        data-effect="slide"
        data-hold="500"
        data-duration="1000"
        data-up="70"
    />
    <Typography
        id="hero-title"
        data-effect="zoom"
        data-duration="800"
        class="honey"
        as="h1"
        variant="heading-l"
        color="primary"
        >Плеер Яндекс Музыки<br />для тех, кто занят делом</Typography
    >
    <Typography
        id="hero-description"
        data-after="hero-title"
        data-effect="slide"
        data-hold="700"
        data-down="70"
        class="description honey"
        as="p"
        variant="text-l"
        color="quaternary"
    >
        Компактный плеер, без лишних раздражителей. Оптимизирован
        для минимального потребления ресурсов. Спроектирован для комфортного
        фонового использования, не отвлекаясь от работы.
    </Typography>
    <div
        data-after="hero-icon"
        data-effect="slide"
        data-down="60"
        data-hold="1000"
        class="honey actions"
        aria-label="Ссылки скачивания"
    >
        <DownloadButton size="m" />
    </div>
</section>

<style lang="scss">
    .hero {
        width: min(100% - calc(var(--layout-padding) * 2), var(--layout-max));
        max-width: 760px;
        margin: 0 auto;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 175px 0 190px;

        h1 {
            margin-top: 68px;
            margin-bottom: 24px;
        }
    }

    .actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-top: 58px;
    }

    .download-button,
    .terminal-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
        padding: 0 16px;
        font-size: var(--text-md);
        font-weight: 700;
        letter-spacing: var(--tracking-widest);
        text-decoration: none;
    }

    .download-button {
        border-radius: var(--radius-md);
        background: var(--color-button-bg);
        color: var(--color-text-inverse);
        box-shadow: inset 0 -1px 0 var(--color-button-shadow);
    }

    .download-button::before {
        content: "";
        width: 10px;
        height: 12px;
        margin-right: 8px;
        border-radius: 4px 4px 5px 5px;
        background: var(--color-text-inverse);
    }

    .terminal-button {
        border: 1px solid var(--color-border-medium);
        border-radius: var(--radius-sm);
        background: var(--color-bg-tertiary);
        color: var(--color-text-terminal);
        font-family: var(--font-family-mono);
    }

    @media (max-width: 800px) {
        .description {
            max-width: 500px;
        }

        .hero {
            padding: 170px 0 150px;
        }

        .app-icon {
            margin-bottom: 38px;
        }

        .actions {
            flex-direction: column;
            align-items: stretch;
        }

        .download-button,
        .terminal-button {
            width: 100%;
        }
    }
</style>
