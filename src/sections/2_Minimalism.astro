---
import FeatureSection from "../components/FeatureSection.astro";
import VideoPlaceholder from "../components/VideoPlaceholder.astro";
---

<FeatureSection
    titleId="mac-title"
    title="Радикальный минимализм"
    description="В Yamumi нет ничего лишнего: ни регулятора громкости,
    ни выбора отдельных треков, ни перемотки по таймлайну.
    Плеер помогает быстро запустить нужный источник и вернуться к делам,
    не превращая музыку в ещё одну задачу."
>
    <img src="/minimalism.png" alt="Minimalism" />
</FeatureSection>

<style>
    img {
        max-width: 350px;
        height: auto;
        aspect-ratio: 700 / 753;
        margin: 0 auto;
        display: block;
    }
</style>
