---
import FeatureSection from "../components/FeatureSection.astro";
import VideoPlaceholder from "../components/VideoPlaceholder.astro";
---

<FeatureSection
    id="overview"
    titleId="music-title"
    title="Музыка там, где вы"
    description="Плеер отображается поверх всех окон и остаётся на своём месте
    даже после смены рабочей области.
    Не нужно искать нужное окно, чтобы поставить лайк."
>
    <video
        class="video honey"
        data-spin="true"
        data-spin-color="#fff"
        data-expose="true"
        autoplay
        loop
        muted
    >
        <source src="/following.webm" type="video/webm" />
        <source src="/following.mp4" type="video/mp4" />
    </video>
</FeatureSection>

<style>
    .video {
        border-radius: 12px;
        width: 100%;
        aspect-ratio: 16 / 9;
    }
</style>
