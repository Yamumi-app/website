---
import Layout from "../layouts/Layout.astro";

import HeroSection from "../sections/1_Hero.astro";
import MinimalismSection from "../sections/2_Minimalism.astro";
import FollowingSection from "../sections/3_Following.astro";
import MoreSection from "../sections/4_More.astro";
import CTASection from "../sections/5_CTA.astro";
import FAQSection from "../sections/6_FAQ.astro";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
    <main class="page">
        <Header />

        <HeroSection />
        <MinimalismSection />
        <FollowingSection />
        <MoreSection />
        <CTASection />
        <FAQSection />

        <Footer />
    </main>
</Layout>

<style>
    .page {
        min-height: 100vh;
        overflow: hidden;
        background:
            radial-gradient(
                circle at 50% 0%,
                rgba(255, 255, 255, 0.035),
                transparent 420px
            ),
            var(--color-bg-primary);
    }
</style>
